    <div class="decision-head">
      <div class="ic"><svg><use href="#ic-bulb"/></svg></div>
      <p id="decisionText">دمج عقود توريد المحاور والبراغي والزنبركات مع مورد واحد أو اثنين بدلاً من خمسة موردين حاليًا، مع التفاوض على خصم كمية بنسبة 15%.</p>
    </div>
    <div class="metric-row" id="decisionMetrics"></div>
    <div class="flow-arrows">
      <button class="arrow-btn" onclick="goStep('step-scenarios')"><svg><use href="#ic-arrow-r"/></svg></button>
      <button class="arrow-btn solid" onclick="goStep('step-final')"><svg><use href="#ic-arrow-l"/></svg></button>
    </div>
  </div>

  <!-- STEP 5 : final recommendation -->
  <div class="flow-card wide flow-step" id="step-final">
    <div id="finalHolder"></div>
    <div class="flow-arrows">
      <button class="arrow-btn" onclick="goStep('step-decision')"><svg><use href="#ic-arrow-r"/></svg></button>
      <button class="btn btn-primary" onclick="finishFlow()">اعتماد القرار وإنهاء</button>
      <span style="width:38px;"></span>
    </div>
  </div>

</div>

<div class="toast" id="toastEl"></div>

<script>
/* ===================== DATA ===================== */
const STATIONS = ['التشكيل بالدرفلة','تجميع الأطفال','تركيب المحور','طاولة التجميع','منطقة التغليف'];
const STATION_ICON = ['🛞','⚙️','🔧','🧰','📦'];
const CURRENT_VALS = [8,15,15,10,8];
const BEST_VALS    = [4,10,10,6,4];
const BOTTLENECK   = [false,true,true,false,false];
const PIE_DATA = [
  {label:'التشكيل بالدرفلة',pct:20,color:'#7c3aed'},
  {label:'تجميع الأطفال',pct:23,color:'#ef4444'},
  {label:'تركيب المحور',pct:23,color:'#3b82f6'},
  {label:'طاولة التجميع',pct:17,color:'#f59e0b'},
  {label:'منطقة التغليف',pct:17,color:'#10b981'},
];

const SCENARIOS = [
  {
    title:'سيناريو 1: تحسين إعداد الآلات (SMED)',
    desc:'إعادة توزيع عمليات قص الألمنيوم من محطة التشكيل إلى محطة التجميع، وتقليل زمن إعداد الآلة من 8 دقائق إلى 5 دقائق بتطبيق منهجية SMED.',
    metrics:[
      {val:'+11%',lab:'استخدام الآلات',cls:'c-green'},
      {val:'-18%',lab:'وقت الانتظار',cls:'c-green'},
      {val:'منخفض',lab:'تكلفة التطبيق',cls:'c-blue'},
    ]
  },
  {
    title:'سيناريو 2: الصيانة الوقائية الذكية',
    desc:'تطبيق برنامج صيانة وقائية ذكية للآلات الدقيقة والفحص، مع تخصيص نافذة زمنية 30 دقيقة يوميًا خارج ساعات الإنتاج بالذروة.',
    metrics:[
      {val:'-60%',lab:'أعطال مفاجئة',cls:'c-green'},
      {val:'+8%',lab:'كفاءة الخط',cls:'c-green'},
      {val:'منخفض',lab:'تكلفة التطبيق',cls:'c-blue'},
    ]
  },
  {
    title:'سيناريو 3: دمج عقود الموردين',
    desc:'دمج عقود توريد المحاور والبراغي والزنبركات مع مورد واحد أو اثنين بدلاً من خمسة موردين حاليًا، مع التفاوض على خصم كمية بنسبة 15%.',
    metrics:[
      {val:'-7%',lab:'تكلفة المواد',cls:'c-green'},
      {val:'>80k',lab:'توفير سنوي (ريال)',cls:'c-green'},
      {val:'متوسط',lab:'تكلفة التطبيق',cls:'c-blue'},
    ]
  }
];
const SELECTED_SCENARIO = 2; // index of the scenario chosen by the system (سيناريو 3)

/* ===================== SCREEN NAV ===================== */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goToApp(){
  showScreen('app-shell');
  renderAll();
}
function setNav(el,viewId,title,sub){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.view').forEach(v=>v.style.display='none');
  document.getElementById(viewId).style.display='block';
  document.getElementById('pageTitle').textContent=title;
  document.getElementById('pageSub').textContent=sub;
  document.getElementById('sidebarEl').classList.remove('open');
}

/* ===================== TOAST ===================== */
function toast(msg){
  const t=document.getElementById('toastEl');
  t.textContent='✓ '+msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2600);
}

/* ===================== CHART BUILDERS ===================== */
function buildTwinRow(targetId){
  const el=document.getElementById(targetId);
  el.innerHTML = STATIONS.map((s,i)=>`
    <div class="twin-station">
      <div class="twin-box ${BOTTLENECK[i]?'bottleneck':''}">
        ${BOTTLENECK[i]?'<span class="twin-tag">عنق زجاجة</span>':''}
        ${STATION_ICON[i]}
      </div>
      <div class="twin-label">${s}</div>
    </div>`).join('');
}

function buildBarChart(targetId){
  const w=460,h=180,pad=28,gap=18;
  const barW=(w-pad*2-gap*4)/5;
  const max=16;
  let bars='';
  CURRENT_VALS.forEach((v,i)=>{
    const bh=(v/max)*(h-pad*2);
    const x=pad+i*(barW+gap);
    const y=h-pad-bh;
    const color=BOTTLENECK[i]?'#e3393b':'#1d52c9';
    bars+=`<rect x="${x}" y="${y}" width="${barW}" height="${bh}" rx="6" fill="${color}"></rect>
           <text x="${x+barW/2}" y="${y-6}" text-anchor="middle" font-size="11" font-weight="700" fill="#152040">${v}</text>`;
  });
  const svg=`<svg viewBox="0 0 ${w} ${h+22}" style="width:100%;height:auto;">
    <line x1="${pad}" y1="${h-pad}" x2="${w-pad}" y2="${h-pad}" stroke="#e7eaf2" stroke-width="1"/>
    ${bars}
    ${STATIONS.map((s,i)=>{const x=pad+i*(barW+gap)+barW/2;return `<text x="${x}" y="${h+14}" text-anchor="middle" font-size="9.5" fill="#6b7593">${shortLabel(s)}</text>`;}).join('')}
  </svg>`;
  document.getElementById(targetId).innerHTML=svg;
}
function shortLabel(s){
  const map={'التشكيل بالدرفلة':'التشكيل','تجميع الأطفال':'تجميع الأطفال','تركيب المحور':'تركيب المحور','طاولة التجميع':'التجميع','منطقة التغليف':'التغليف'};
  return map[s]||s;
}

function buildLineChart(targetId){
  const w=460,h=190,pad=28;
  const innerW=w-pad*2, innerH=h-pad*2-14;
  const n=STATIONS.length;
  const xStep=innerW/(n-1);
  const max=16;
  const pts=(arr)=>arr.map((v,i)=>{
    const x=pad+i*xStep;
    const y=pad+innerH-(v/max)*innerH;
    return [x,y];
  });
  const curPts=pts(CURRENT_VALS), bestPts=pts(BEST_VALS);
  const toPath=(p)=>p.map((pt,i)=>(i===0?'M':'L')+pt[0].toFixed(1)+','+pt[1].toFixed(1)).join(' ');
  const dots=(p,color)=>p.map(pt=>`<circle cx="${pt[0]}" cy="${pt[1]}" r="4" fill="${color}"/>`).join('');
  const labels=(p,arr,color)=>p.map((pt,i)=>`<text x="${pt[0]}" y="${pt[1]-9}" text-anchor="middle" font-size="10.5" font-weight="700" fill="${color}">${arr[i]}</text>`).join('');
  const svg=`<svg viewBox="0 0 ${w} ${h+10}" style="width:100%;height:auto;">
    <line x1="${pad}" y1="${pad+innerH}" x2="${w-pad}" y2="${pad+innerH}" stroke="#e7eaf2"/>
    <path d="${toPath(curPts)}" fill="none" stroke="#e3393b" stroke-width="2.5"/>
    <path d="${toPath(bestPts)}" fill="none" stroke="#19a64b" stroke-width="2.5"/>
    ${dots(curPts,'#e3393b')}${dots(bestPts,'#19a64b')}
    ${labels(curPts,CURRENT_VALS,'#e3393b')}
    ${labels(bestPts,BEST_VALS,'#19a64b')}
    ${STATIONS.map((s,i)=>`<text x="${pad+i*xStep}" y="${h}" text-anchor="middle" font-size="9.5" fill="#6b7593">${shortLabel(s)}</text>`).join('')}
  </svg>`;
  document.getElementById(targetId).innerHTML=svg;
}

function buildPie(targetId){
  let acc=0;
  const stops=PIE_DATA.map(d=>{
    const start=acc, end=acc+d.pct;
    acc=end;
    return `${d.color} ${start}% ${end}%`;
  }).join(',');
  const html=`
    <div class="pie-circle" style="background:conic-gradient(${stops});"></div>
    <ul class="pie-legend">
      ${PIE_DATA.map(d=>`<li><span class="legend-dot" style="background:${d.color}"></span>${d.label} <b>${d.pct}%</b></li>`).join('')}
    </ul>`;
  document.getElementById(targetId).innerHTML=html;
}

/* ===================== SCENARIO CARDS ===================== */
function scenarioCardHTML(sc,idx,clickable){
  return `<div class="scenario-card" ${clickable?`onclick="selectScenario(${idx})"`:''}>
    <div class="scenario-num">0${idx+1}</div>
    <div style="font-size:13px;font-weight:800;margin-bottom:8px;">${sc.title}</div>
    <div class="scenario-desc">${sc.desc}</div>
    <div class="metric-row">
      ${sc.metrics.map(m=>`<div class="metric-pill"><div class="m-val ${m.cls}">${m.val}</div><div class="m-lab">${m.lab}</div></div>`).join('')}
    </div>
  </div>`;
}
function buildScenarioGrids(){
  document.getElementById('scenarioGridFull').innerHTML = SCENARIOS.map((sc,i)=>scenarioCardHTML(sc,i,false)).join('');
  document.getElementById('scenarioGridFlow').innerHTML = SCENARIOS.map((sc,i)=>scenarioCardHTML(sc,i,true)).join('');
}
let currentScenarioIdx = SELECTED_SCENARIO;
function selectScenario(idx){
  currentScenarioIdx=idx;
  const sc=SCENARIOS[idx];
  document.getElementById('decisionText').textContent=sc.desc;
  document.getElementById('decisionMetrics').innerHTML = sc.metrics.map(m=>`<div class="metric-pill"><div class="m-val ${m.cls}">${m.val}</div><div class="m-lab">${m.lab}</div></div>`).join('');
  buildFinalPanel();
  goStep('step-decision');
}

/* ===================== FINAL RECOMMENDATION PANEL ===================== */
function finalPanelHTML(chartId){
  return `
  <div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:18px;">
    <div class="stat-card"><div class="stat-icon bg-red"><svg><use href="#ic-clock"/></svg></div><div class="stat-label">زمن الإنتاج الحالي</div><div class="stat-value c-red">66</div><div class="stat-unit">دقيقة</div></div>
    <div class="stat-card"><div class="stat-icon bg-green"><svg><use href="#ic-clock"/></svg></div><div class="stat-label">زمن الإنتاج الأفضل</div><div class="stat-value c-green">52</div><div class="stat-unit">دقيقة</div></div>
    <div class="stat-card"><div class="stat-icon bg-green"><svg><use href="#ic-trend"/></svg></div><div class="stat-label">التحسن</div><div class="stat-value c-green">27%</div><div class="stat-unit">&nbsp;</div></div>
  </div>
  <div class="panel" style="margin-bottom:16px;">
    <h3 class="panel-title"><svg><use href="#ic-trend"/></svg>مقاضنة الأداء</h3>
    <div class="legend-row"><span><span class="legend-dot" style="background:var(--danger)"></span>الحالي</span><span><span class="legend-dot" style="background:var(--success)"></span>الأفضل</span></div>
    <div id="${chartId}"></div>
  </div>
  <div class="panel">
    <h3 class="panel-title"><svg><use href="#ic-trophy"/></svg>التوصية والقرار المقترح</h3>
    <p style="font-size:12px;color:var(--muted);margin:-6px 0 12px;">القرار الموصى به: ${SCENARIOS[currentScenarioIdx].desc}</p>
    <div class="compare-grid">
      <div class="compare-box current">
        <h5>الوضع الحالي</h5>
        <div class="compare-line"><span>زمن الإنتاج اليومي</span><b>66 دقيقة</b></div>
        <div class="compare-line"><span>الإنتاج اليومي</span><b>40 باب</b></div>
        <div class="compare-line"><span>العنق الرجاجة</span><b>تجميع / تركيب</b></div>
      </div>
      <div class="arrow-mid"><svg><use href="#ic-arrow-l"/></svg></div>
      <div class="compare-box proposed">
        <h5>بعد تطبيق القرار المقترح</h5>
        <div class="compare-line"><span>زمن الإنتاج اليومي</span><b>52 دقيقة</b></div>
        <div class="compare-line"><span>الإنتاج اليومي</span><b>51 باب</b></div>
        <div class="compare-line"><span>تحسّن الأداء</span><b class="c-green">27%</b></div>
      </div>
    </div>
    <div class="why-list">
      <div class="why-item"><svg><use href="#ic-check"/></svg>يحقق أعلى تحسن بأقل تكلفة</div>
      <div class="why-item"><svg><use href="#ic-check"/></svg>يقلل زمن الانتظار وقوائم العمل</div>
      <div class="why-item"><svg><use href="#ic-check"/></svg>سهل التنفيذ ولا يحتاج تغيير كبير في الخط</div>
    </div>
    <div class="final-banner"><svg><use href="#ic-trophy"/></svg>توصية النظام: اعتماد هذا القرار لتحقيق أفضل أداء بأقل تكلفة.</div>
  </div>`;
}
function buildFinalPanel(){
  document.getElementById('finalHolder').innerHTML=finalPanelHTML('lineChart3');
  buildLineChart('lineChart3');
  document.getElementById('recHolder').innerHTML=finalPanelHTML('lineChart4');
  buildLineChart('lineChart4');
}

/* ===================== FLOW OVERLAY CONTROL ===================== */
function startFlow(){
  document.getElementById('flowOverlay').classList.add('active');
  goStep('step-data');
}
function closeFlow(){
  document.getElementById('flowOverlay').classList.remove('active');
}
function goStep(id){
  document.querySelectorAll('.flow-step').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function runThinking(){
  const fill=document.getElementById('progressFill');
  fill.style.width='0%';
  setTimeout(()=>{fill.style.width='100%';},50);
  setTimeout(()=>{
    goStep('step-scenarios');
  },2700);
}
function finishFlow(){
  closeFlow();
  setNav(document.querySelector('[data-view="view-rec"]'),'view-rec','التوصيات','القرار الموصى به من النظام');
  toast('تم اعتماد القرار بنجاح');
}

/* ===================== INITIAL RENDER ===================== */
function renderAll(){
  buildTwinRow('twinRow1');
  buildTwinRow('twinRow2');
  buildBarChart('barChart1');
  buildBarChart('barChart2');
  buildLineChart('lineChart1');
  buildLineChart('lineChart2');
  buildPie('pieWrap1');
  buildPie('pieWrap2');
  buildScenarioGrids();
  selectScenario(SELECTED_SCENARIO);
}
</script>
</body>
</html>
