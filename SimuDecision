<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SimuDecision AI | منصة المحاكاة والقرارات الذكية</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --navy-900:#0a1730;
  --navy-800:#0f2046;
  --navy-700:#16315f;
  --card:#ffffff;
  --input-bg:#f4eee0;
  --input-border:#3a5790;
  --primary:#1d52c9;
  --primary-dark:#143a96;
  --primary-light:#e8f0ff;
  --success:#19a64b;
  --success-light:#e7f8ec;
  --danger:#e3393b;
  --danger-light:#fdebec;
  --text:#152040;
  --muted:#6b7593;
  --border:#e7eaf2;
  --radius-lg:20px;
  --radius-md:14px;
  --radius-sm:9px;
  --shadow:0 18px 45px -15px rgba(8,18,46,.35);
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  font-family:'Tajawal',sans-serif;
  background:radial-gradient(circle at 80% -10%, #1a3a72 0%, var(--navy-900) 45%);
  color:var(--text);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
}
button{font-family:inherit;cursor:pointer;border:none;}
input{font-family:inherit;}
a{text-decoration:none;}
::selection{background:#7da4ff;color:#fff;}

/* ============ LAYOUT SHELLS ============ */
.screen{display:none;}
.screen.active{display:block;}
.center-shell{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:40px 16px;
}

/* logo */
.brand{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:26px;}
.brand-mark{width:54px;height:54px;flex-shrink:0;}
.brand-name{color:#fff;font-weight:800;font-size:20px;letter-spacing:.3px;}
.brand-name span{color:#7fb1ff;}

/* auth card */
.auth-card{
  background:var(--card);
  border-radius:var(--radius-lg);
  padding:38px 36px 30px;
  width:100%;
  max-width:380px;
  box-shadow:var(--shadow);
}
.auth-title{font-size:21px;font-weight:800;margin:0 0 22px;text-align:center;color:var(--text);}
.field{margin-bottom:16px;}
.field label{display:block;font-size:13px;font-weight:700;color:var(--text);margin-bottom:7px;}
.input-wrap{position:relative;}
.input-wrap input{
  width:100%;
  background:var(--input-bg);
  border:1.5px solid #e6d9b8;
  border-radius:12px;
  padding:13px 42px 13px 14px;
  font-size:13px;
  color:var(--text);
  outline:none;
  transition:border-color .15s;
}
.input-wrap input:focus{border-color:var(--primary);}
.input-wrap .icon{
  position:absolute;left:14px;top:50%;transform:translateY(-50%);
  width:18px;height:18px;color:#8b96b8;
}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  border-radius:12px;font-weight:700;font-size:14px;padding:13px 22px;
  transition:transform .12s, box-shadow .12s, background .15s;
}
.btn:active{transform:scale(.97);}
.btn-block{width:100%;}
.btn-primary{background:var(--primary);color:#fff;box-shadow:0 10px 24px -8px rgba(29,82,201,.55);}
.btn-primary:hover{background:var(--primary-dark);}
.btn-ghost{background:transparent;color:var(--primary);}
.switch-line{text-align:center;font-size:12.5px;color:var(--muted);margin-top:16px;}
.switch-line button{background:none;color:var(--primary);font-weight:700;font-size:12.5px;padding:0;}
.secure-note{text-align:center;font-size:11px;color:#aeb8d6;margin-top:18px;display:flex;align-items:center;justify-content:center;gap:6px;}

/* ============ APP SHELL (dashboard) ============ */
#app-shell{direction:ltr;display:flex;min-height:100vh;background:linear-gradient(160deg,var(--navy-900),#0d1c3c 60%);}
.sidebar{
  width:226px;flex-shrink:0;background:var(--navy-800);
  padding:22px 14px 18px;display:flex;flex-direction:column;
  border-left:1px solid rgba(255,255,255,.06);
  direction:rtl;
}
.sidebar-logo{display:flex;align-items:center;gap:10px;padding:0 6px 20px;border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:14px;}
.sidebar-logo .brand-mark{width:38px;height:38px;}
.sidebar-logo .brand-name{font-size:14.5px;}
.nav-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:3px;flex:1;}
.nav-item{
  display:flex;align-items:center;gap:11px;padding:11px 13px;border-radius:11px;
  color:#b9c3e3;font-size:13.5px;font-weight:600;transition:background .15s,color .15s;
}
.nav-item svg{width:18px;height:18px;flex-shrink:0;}
.nav-item:hover{background:rgba(255,255,255,.06);color:#fff;}
.nav-item.active{background:var(--primary);color:#fff;box-shadow:0 8px 18px -6px rgba(29,82,201,.6);}
.sidebar-user{display:flex;align-items:center;gap:10px;padding:12px 8px;border-top:1px solid rgba(255,255,255,.08);margin-top:10px;}
.avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#7fb1ff,#5169e6);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;flex-shrink:0;}
.user-meta{line-height:1.2;}
.user-meta .name{font-size:13px;font-weight:700;color:#fff;}
.user-meta .role{font-size:11px;color:#8c98c2;}

.main-area{flex:1;direction:rtl;padding:22px 26px 40px;overflow-x:hidden;min-width:0;}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:12px;}
.page-title{color:#fff;font-size:19px;font-weight:800;margin:0;}
.page-sub{color:#9aa6cc;font-size:12.5px;margin-top:3px;}

/* stat cards */
.stat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:20px;}
@media (max-width:1100px){.stat-grid{grid-template-columns:repeat(2,1fr);}}
.stat-card{background:var(--card);border-radius:var(--radius-md);padding:16px 14px;box-shadow:var(--shadow);display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;}
.stat-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;}
.stat-icon svg{width:18px;height:18px;}
.stat-label{font-size:11.5px;color:var(--muted);font-weight:700;}
.stat-value{font-size:21px;font-weight:800;}
.stat-unit{font-size:10.5px;color:var(--muted);margin-top:-4px;}
.c-red{color:var(--danger);} .c-green{color:var(--success);} .c-blue{color:var(--primary);}
.bg-red{background:var(--danger-light);color:var(--danger);}
.bg-green{background:var(--success-light);color:var(--success);}
.bg-blue{background:var(--primary-light);color:var(--primary);}

/* generic content grid */
.grid-2{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
@media (max-width:1000px){.grid-2,.grid-3{grid-template-columns:1fr;}}
.panel{background:var(--card);border-radius:var(--radius-md);padding:18px 18px 14px;box-shadow:var(--shadow);}
.panel-title{font-size:14.5px;font-weight:800;margin:0 0 14px;display:flex;align-items:center;gap:8px;}
.panel-title svg{width:16px;height:16px;color:var(--primary);}

/* twin line */
.twin-row{display:flex;justify-content:space-between;gap:8px;padding:6px 2px 4px;}
.twin-station{flex:1;text-align:center;}
.twin-box{
  background:#f6f8fc;border:2px solid var(--border);border-radius:12px;
  padding:14px 6px 10px;font-size:35px;line-height:1;position:relative;
}
.twin-box.bottleneck{border-color:var(--danger);background:var(--danger-light);}
.twin-tag{position:absolute;top:-9px;left:50%;transform:translateX(-50%);background:var(--danger);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;white-space:nowrap;}
.twin-label{font-size:11px;font-weight:700;margin-top:8px;color:var(--text);}

/* legend */
.legend-row{display:flex;align-items:center;gap:14px;font-size:11.5px;color:var(--muted);margin-bottom:8px;}
.legend-dot{width:9px;height:9px;border-radius:50%;display:inline-block;margin-left:5px;}

/* pie legend */
.pie-wrap{display:flex;align-items:center;gap:18px;}
.pie-circle{width:120px;height:120px;border-radius:50%;flex-shrink:0;}
.pie-legend{display:flex;flex-direction:column;gap:7px;font-size:12px;}
.pie-legend li{list-style:none;display:flex;align-items:center;gap:7px;}
.pie-legend b{font-weight:800;}

/* benefits */
.benefit-list{display:flex;flex-direction:column;gap:12px;}
.benefit-item{display:flex;align-items:center;gap:11px;}
.benefit-icon{width:34px;height:34px;border-radius:10px;background:var(--success-light);color:var(--success);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.benefit-icon svg{width:17px;height:17px;}
.benefit-text{font-size:12px;color:var(--muted);}
.benefit-val{font-size:14.5px;font-weight:800;color:var(--text);}

/* buttons top */
.btn-start{background:var(--primary);color:#fff;padding:11px 26px;border-radius:12px;font-weight:800;font-size:13.5px;box-shadow:0 10px 22px -8px rgba(29,82,201,.6);}
.btn-start:hover{background:var(--primary-dark);}

/* simple placeholder card */
.placeholder-card{background:var(--card);border-radius:var(--radius-md);padding:34px 18px;text-align:center;box-shadow:var(--shadow);}
.placeholder-card .ph-icon{width:54px;height:54px;border-radius:16px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.placeholder-card .ph-icon svg{width:26px;height:26px;}
.placeholder-card h3{margin:0 0 6px;font-size:15px;font-weight:800;}
.placeholder-card p{margin:0;font-size:12.5px;color:var(--muted);}

/* settings form reuse field */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media (max-width:700px){.settings-grid{grid-template-columns:1fr;}}

/* ============ FLOW OVERLAY ============ */
.overlay{
  position:fixed;inset:0;background:radial-gradient(circle at 80% -10%,#1a3a72 0%, var(--navy-900) 45%);
  z-index:50;display:none;align-items:center;justify-content:center;padding:30px 16px;
  overflow-y:auto;
}
.overlay.active{display:flex;}
.flow-card{background:var(--card);border-radius:var(--radius-lg);padding:32px 30px;width:100%;max-width:560px;box-shadow:var(--shadow);position:relative;}
.flow-card.wide{max-width:960px;}
.flow-step{display:none;}
.flow-step.active{display:block;animation:fadeUp .35s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.flow-arrows{display:flex;justify-content:space-between;margin-top:26px;}
.arrow-btn{width:38px;height:38px;border-radius:10px;background:var(--navy-800);color:#fff;display:flex;align-items:center;justify-content:center;}
.arrow-btn svg{width:17px;height:17px;}
.arrow-btn:disabled{opacity:.35;cursor:not-allowed;}
.arrow-btn.solid{background:var(--primary);}

/* form fields (data entry) */
.form-title{font-size:15.5px;font-weight:800;text-align:center;margin:0 0 22px;}

/* thinking screen */
.think-box{background:var(--card);border-radius:var(--radius-lg);padding:50px 40px;text-align:center;box-shadow:var(--shadow);}
.gears{display:flex;justify-content:center;align-items:center;gap:4px;margin-bottom:22px;height:70px;}
.gear{width:46px;height:46px;color:var(--primary);}
.gear.small{width:30px;height:30px;color:#8bb0ff;}
.gear.spin{animation:spin 2.4s linear infinite;}
.gear.spin-rev{animation:spin 1.8s linear infinite reverse;}
@keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.think-title{font-size:17px;font-weight:800;margin:0 0 8px;}
.think-sub{font-size:12.5px;color:var(--muted);}
.think-dots span{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--primary);margin:0 3px;animation:bounce 1.2s infinite ease-in-out;}
.think-dots span:nth-child(2){animation-delay:.15s;}
.think-dots span:nth-child(3){animation-delay:.3s;}
@keyframes bounce{0%,80%,100%{transform:scale(.6);opacity:.4;}40%{transform:scale(1);opacity:1;}}
.progress-track{height:6px;border-radius:6px;background:#eef1f8;margin-top:24px;overflow:hidden;}
.progress-fill{height:100%;width:0%;background:var(--primary);border-radius:6px;transition:width 2.6s linear;}

/* scenario cards */
.scenario-card{background:#fff;border-radius:var(--radius-md);padding:20px 16px;box-shadow:var(--shadow);border:2px solid transparent;cursor:pointer;transition:border-color .15s, transform .15s;display:flex;flex-direction:column;height:100%;}
.scenario-card:hover{border-color:var(--primary);transform:translateY(-3px);}
.scenario-num{width:36px;height:36px;border-radius:10px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-bottom:12px;}
.scenario-desc{font-size:12.5px;color:var(--text);line-height:1.7;flex:1;margin-bottom:14px;}
.metric-row{display:flex;flex-wrap:wrap;gap:8px;}
.metric-pill{flex:1;min-width:90px;background:#f4f7fc;border-radius:10px;padding:9px 6px;text-align:center;}
.metric-pill .m-val{font-size:13px;font-weight:800;}
.metric-pill .m-lab{font-size:10px;color:var(--muted);margin-top:2px;}

/* decision detail */
.decision-head{display:flex;gap:12px;align-items:center;margin-bottom:16px;}
.decision-head .ic{width:46px;height:46px;border-radius:12px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.decision-head .ic svg{width:24px;height:24px;}
.decision-head p{margin:0;font-size:13.5px;font-weight:700;}

/* recommendation final */
.compare-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:center;margin:16px 0;}
.compare-box{border-radius:14px;padding:14px 14px 10px;}
.compare-box.current{background:var(--danger-light);}
.compare-box.proposed{background:var(--success-light);}
.compare-box h5{margin:0 0 10px;font-size:12px;font-weight:800;text-align:center;}
.compare-box.current h5{color:var(--danger);}
.compare-box.proposed h5{color:var(--success);}
.compare-line{display:flex;justify-content:space-between;font-size:11.5px;padding:6px 0;border-top:1px dashed rgba(0,0,0,.08);}
.compare-line:first-of-type{border-top:none;}
.compare-line b{font-size:13px;}
.arrow-mid{width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;}
.arrow-mid svg{width:16px;height:16px;}
.why-list{display:flex;flex-direction:column;gap:8px;margin:14px 0;}
.why-item{display:flex;align-items:center;gap:9px;font-size:12px;color:var(--text);}
.why-item svg{width:16px;height:16px;color:var(--success);flex-shrink:0;}
.final-banner{background:var(--success);color:#fff;border-radius:14px;padding:13px 16px;display:flex;align-items:center;gap:10px;font-size:12.5px;font-weight:700;margin-top:8px;}
.final-banner svg{width:18px;height:18px;flex-shrink:0;}

/* toast */
.toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--success);color:#fff;padding:13px 22px;border-radius:12px;font-size:13px;font-weight:700;box-shadow:0 14px 30px -10px rgba(0,0,0,.4);opacity:0;transition:.3s;z-index:80;display:flex;align-items:center;gap:8px;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* scrollbar */
::-webkit-scrollbar{width:8px;}
::-webkit-scrollbar-thumb{background:#cbd5f0;border-radius:8px;}

@media (max-width:760px){
  .sidebar{position:fixed;z-index:40;height:100vh;left:0;transform:translateX(-100%);transition:transform .25s;}
  .sidebar.open{transform:translateX(0);}
  .main-area{padding:18px 14px 60px;}
  .menu-toggle{display:flex !important;}
}
.menu-toggle{display:none;width:38px;height:38px;border-radius:10px;background:var(--navy-800);color:#fff;align-items:center;justify-content:center;}
.menu-toggle svg{width:18px;height:18px;}
</style>
</head>
